# ============================================================================
# Orbit — Nginx reverse proxy / load balancer  (REFERENCE ONLY)
# ============================================================================
# This file documents the INTENDED edge routing. It is NOT wired into any
# environment yet. TLS, load balancing across Kubernetes replicas, and the
# production ingress are finalized in the deployment phase (see CLAUDE.md →
# Deployment). Copy/adapt this into the real config at that time.
#
# Contract (from the product spec):
#   orbit.com/api/users/*   ->  users-service:3001      (REST)
#   orbit.com/api/posts/*   ->  content-service:3002    (REST)
#   orbit.com/ws/chat/*     ->  chat-service:3003       (WebSocket)
#   orbit.com/*             ->  orbit-frontend:3000      (Next.js)
# ============================================================================

# Upstreams — in Kubernetes these resolve to Services that load-balance across
# the pod replicas of each Deployment.
upstream users_service   { server users-service:3001; }
upstream content_service { server content-service:3002; }
upstream chat_service    { server chat-service:3003; }
upstream notifications_service { server notifications-service:3004; }
upstream orbit_frontend  { server orbit-frontend:3000; }

# Required for WebSocket upgrades (chat, live notifications).
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80;
    server_name orbit.com;
    # In production: listen 443 ssl; + certificate config (deployment phase).

    # --- REST: users domain -------------------------------------------------
    location /api/users/ {
        proxy_pass http://users_service;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # --- REST: content/posts domain ----------------------------------------
    location /api/posts/ {
        proxy_pass http://content_service;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # --- WebSocket: chat ----------------------------------------------------
    location /ws/chat/ {
        proxy_pass http://chat_service;
        proxy_http_version 1.1;
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host       $host;
        proxy_read_timeout 3600s; # keep long-lived sockets open
    }

    # --- Everything else: the Next.js frontend ------------------------------
    location / {
        proxy_pass http://orbit_frontend;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
